{
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "**/*.yml"
        ],
        "exclude": [
          "**/obj/**",
          "**/includes/**",
          "**/_themes/**",
          "api/overwrites/**",
          "README.md",
          "LICENSE",
          "LICENSE-CODE",
          "ThirdPartyNotices"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "**/*.png",
          "**/*.jpg",
          "**/*.svg",
          "**/*.gif",
          "**/*.bmp"
        ],
        "exclude": [
          "**/obj/**",
          "**/includes/**"
        ]
      }
    ],
    "overwrite": {
      "files": [
        "api/overwrites/**/*.md"
      ]
    },
    "globalMetadata": {
      "ms.subservice": "sdk",
      "ms.service": "lync",
      "feedback_system": "Standard",
      "apiPlatform": "dotnet",
      "breadcrumb_path": "/previous-versions/dotnet/breadcrumb/toc.yml",
      "author": "o365devx",
      "ms.author": "o365devx",
      "manager": "davech",
      "ms.date": "6/1/2018",
      "ms.topic": "reference",
      "audience": "developer",
      "ms.reviewer": "",
      "ms.suite": "office",
      "ms.tgt_pltfrm": "dotnet",
      "apiPlatform": "dotnet",
       "ROBOTS": "NOINDEX,NOFOLLOW",
      "is_archived": true,
      "is_retired": true, 
      "feedback_system": "None",
      "learn_archive": "manual"
    },
    "fileMetadata": {
      "author": {
        "api/**.yml": "dotnet-bot"
      }
    },
    "template": [],
    "isCanonicalUrlWithMoniker": true,
    "dest": "_site",
    "xref": [
      "_zip/msdn.4.5.2.zip"
    ],
    "lruSize": 0
  }
}
